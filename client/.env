# Frontend API URL
# Point to your backend server
VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_API_URL=http://127.0.0.1:8000
VITE_SOCKET_URL=http://127.0.0.1:8000

# Socket.io event names — only change if your server uses
# different event strings.
VITE_SOCKET_EMIT_EVENT=query:start
VITE_SOCKET_START_EVENT=query:started
VITE_SOCKET_TOKEN_EVENT=query:token
VITE_SOCKET_COMPLETE_EVENT=query:complete
VITE_SOCKET_ERROR_EVENT=query:error